# DataGuardian Pro - Production Environment Template
# ================================================
# Copy this file to .env on your production server and fill in values
# NEVER commit .env to git - only .env.template
#
# Usage:
#   ssh root@45.81.35.202
#   cd /opt/dataguardian
#   cp .env.template .env
#   nano .env  # Fill in values
#   chmod 600 .env

# ======================
# DATABASE CONFIGURATION
# ======================
POSTGRES_USER=dataguardian
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
POSTGRES_DB=dataguardian_prod
DATABASE_URL=postgresql://dataguardian:CHANGE_ME_GENERATE_STRONG_PASSWORD@postgres:5432/dataguardian_prod

# ======================
# REDIS CONFIGURATION
# ======================
REDIS_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
REDIS_URL=redis://:CHANGE_ME_GENERATE_STRONG_PASSWORD@redis:6379/0

# ======================
# APPLICATION SECRETS
# ======================
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_256_BIT_SECRET
ENCRYPTION_KEY=CHANGE_ME_GENERATE_256_BIT_KEY
DATAGUARDIAN_MASTER_KEY=CHANGE_ME_YOUR_MASTER_KEY

# ======================
# EXTERNAL SERVICES
# ======================
OPENAI_API_KEY=sk-CHANGE_ME
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME

# ======================
# DOCKER CONFIGURATION
# ======================
DOCKER_IMAGE=your-dockerhub-username/dataguardian-app
DOCKER_WORKER_IMAGE=your-dockerhub-username/dataguardian-worker
APP_VERSION=latest

# ======================
# DEPLOYMENT SETTINGS
# ======================
ENVIRONMENT=production
ACTIVE_COLOR=blue
WORKER_REPLICAS=3
