modules = ["python-3.11", "python3", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = ["abseil-cpp", "cacert", "cairo", "cargo", "ffmpeg-full", "file", "fontconfig", "freetype", "ghostscript", "glib", "glibcLocales", "gmp", "gobject-introspection", "gtest", "gtk3", "harfbuzz", "lcms2", "libGL", "libGLU", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "libyaml", "oneDNN", "openjpeg", "openssl", "pango", "pkg-config", "qhull", "re2", "rustc", "tcl", "tesseract", "tk", "unixODBC", "zlib"]

[deployment]
deploymentTarget = "autoscale"
run = ["streamlit", "run", "app.py", "--server.port", "5000"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Streamlit Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Redis Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Webhook Server"

[[workflows.workflow]]
name = "Streamlit Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run app.py --server.port 5000 --server.address 0.0.0.0 --server.headless true"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Redis Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "redis-server --port 6379 --bind 0.0.0.0"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Webhook Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python services/webhook_server.py"
waitForPort = 5001

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 6379
externalPort = 4200

[[ports]]
localPort = 8501
externalPort = 3000

[[ports]]
localPort = 33515
externalPort = 6800

[[ports]]
localPort = 33697
externalPort = 8000

[[ports]]
localPort = 37883
externalPort = 5000

[[ports]]
localPort = 40203
externalPort = 5173

[[ports]]
localPort = 40741
externalPort = 6000

[[ports]]
localPort = 42247
externalPort = 3002

[[ports]]
localPort = 43121
externalPort = 3003

[[ports]]
localPort = 44481
externalPort = 8008

[agent]

[userenv]

[userenv.shared]
STRIPE_PRICE_STARTUP_MONTHLY = "price_startup_monthly"
STRIPE_PRICE_STARTUP_ANNUAL = "price_startup_annual"
STRIPE_PRICE_PROFESSIONAL_MONTHLY = "price_professional_monthly"
STRIPE_PRICE_PROFESSIONAL_ANNUAL = "price_professional_annual"
STRIPE_PRICE_GROWTH_MONTHLY = "price_growth_monthly"
STRIPE_PRICE_GROWTH_ANNUAL = "price_growth_annual"
STRIPE_PRICE_SCALE_MONTHLY = "price_scale_monthly"
STRIPE_PRICE_SCALE_ANNUAL = "price_scale_annual"
STRIPE_PRICE_SALESFORCE_MONTHLY = "price_salesforce_monthly"
STRIPE_PRICE_SALESFORCE_ANNUAL = "price_salesforce_annual"
STRIPE_PRICE_SAP_MONTHLY = "price_sap_monthly"
STRIPE_PRICE_SAP_ANNUAL = "price_sap_annual"
STRIPE_PRICE_ENTERPRISE_MONTHLY = "price_enterprise_monthly"
STRIPE_PRICE_ENTERPRISE_ANNUAL = "price_enterprise_annual"
